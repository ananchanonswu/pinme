{
  "version": 2,
  "builds": [
    {
      "src": "api/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "pinme_website/front_end/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/scan",
      "dest": "/api/scan.js"
    },
    {
      "src": "/api/image",
      "dest": "/api/image.js"
    },
    {
      "src": "/scan",
      "dest": "/api/scan.js"
    },
    {
      "src": "/image",
      "dest": "/api/image.js"
    },
    {
      "src": "/",
      "dest": "/pinme_website/front_end/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/pinme_website/front_end/$1"
    }
  ]
}
